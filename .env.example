APP_NAME="CK-MEMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Bangkok

APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=th_TH

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ck_mems
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ck-mems.local"
MAIL_FROM_NAME="${APP_NAME}"

# CK-MEMS: JWT (run `php artisan jwt:secret --force` to populate)
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=10080
JWT_ALGO=HS256

# CK-MEMS: MOPH Alert
MOPH_ALERT_ENABLED=false
MOPH_ALERT_URL=https://morpromt2f.moph.go.th/api/notify/send
MOPH_ALERT_CLIENT_KEY=
MOPH_ALERT_SECRET_KEY=

# CK-MEMS: Hospital tenant default (used by HospitalSeeder)
DEFAULT_HOSPITAL_CODE=CK
DEFAULT_HOSPITAL_NAME="โรงพยาบาลเชียงกลาง"

# CK-MEMS: MOPH Provider ID OAuth (stub — real values come with MOPH PID docs)
PROVIDER_ID_CLIENT_ID=
PROVIDER_ID_CLIENT_SECRET=
PROVIDER_ID_AUTH_URL=
PROVIDER_ID_TOKEN_URL=
PROVIDER_ID_USERINFO_URL=

VITE_APP_NAME="${APP_NAME}"
